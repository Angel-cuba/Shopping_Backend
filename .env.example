# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Database (dev: PostgreSQL on port 5433)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=shopping_db
DB_USERNAME=shopping_user
DB_PASSWORD=yourpassword

# JWT — must be at least 32 chars for HS256
SECRET_KEY=replace_with_at_least_32_char_secret_key_here
